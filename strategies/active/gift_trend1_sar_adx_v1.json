{
  "name": "기프트 추세1 (SAR + ADX)",
  "version": "1.0",
  "status": "testing",
  "description": "주식단테 기프트세트 - 추세1 전략. Parabolic SAR 크로스업 + ADX DI+>DI- 조합. 5분봉 해외선물 기준 최적화, 일봉에서도 사용 가능.",
  "markets": ["kr_stock", "us_stock", "crypto_futures"],
  "direction": "both",
  "timeframes": ["5m", "1d"],
  "indicators": [
    {"name": "SAR", "params": {"acceleration": 0.002, "maximum": 0.12}, "output": "sar"},
    {"name": "PLUS_DI", "params": {"timeperiod": 20}, "output": "plus_di"},
    {"name": "MINUS_DI", "params": {"timeperiod": 20}, "output": "minus_di"}
  ],
  "entry": {
    "logic": "and",
    "conditions": [
      {"left": "close", "op": "crosses_above", "right": "sar"},
      {"left": "plus_di", "op": "gt", "right": "minus_di"}
    ]
  },
  "exit": {
    "logic": "and",
    "conditions": [
      {"left": "close", "op": "crosses_below", "right": "sar"},
      {"left": "minus_di", "op": "gt", "right": "plus_di"}
    ]
  },
  "risk": {
    "stop_loss_pct": 0.03,
    "take_profit_pct": null,
    "risk_per_trade_pct": 0.02,
    "trailing_stop_pct": null
  },
  "metadata": {
    "created_at": "2026-02-27",
    "source_references": ["raw/주식단테_기프트세트_해외선물/"],
    "tags": ["trend-following", "sar", "adx", "주식단테", "기프트세트"],
    "notes": "원본 변수: period=20, af=0.002, maxaf=0.12, a=3(지연봉수). a(지연)는 ta-lib SAR에서 미지원하여 생략. 매수진입=매도청산, 매수청산=매도진입 대칭 구조."
  }
}
