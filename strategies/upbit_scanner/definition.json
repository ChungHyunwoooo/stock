{
  "name": "Upbit Scanner (10종)",
  "version": "1.0",
  "status": "deprecated",
  "description": "EMA_RSI_VWAP, SUPERTREND, MACD_DIV, STOCH_RSI, FIBONACCI, ICHIMOKU, EARLY_PUMP, SMC, HIDDEN_DIV, BB_RSI_STOCH 등 10개 개별 스캐너 복합체. 파일 난립 문제로 pattern_alert 단일 오케스트레이터로 통합 후 폐기.",
  "markets": ["crypto_futures"],
  "direction": "both",
  "timeframes": ["1h", "4h", "1d"],
  "indicators": [
    {"name": "EMA", "params": {"timeperiod": 20}, "output": "ema_20"},
    {"name": "RSI", "params": {"timeperiod": 14}, "output": "rsi_14"},
    {"name": "MACD", "params": {"fastperiod": 12, "slowperiod": 26, "signalperiod": 9}, "output": {"macd": "macd", "signal": "macd_signal", "hist": "macd_hist"}},
    {"name": "STOCHRSI", "params": {"timeperiod": 14}, "output": {"fastk": "stochrsi_k", "fastd": "stochrsi_d"}},
    {"name": "BBANDS", "params": {"timeperiod": 20, "nbdevup": 2, "nbdevdn": 2}, "output": {"upperband": "bb_upper", "middleband": "bb_middle", "lowerband": "bb_lower"}}
  ],
  "entry": {
    "logic": "or",
    "conditions": [
      {"left": "scanner_signal_count", "op": "gte", "right": 2, "label": "composite_signal"}
    ]
  },
  "exit": {
    "logic": "or",
    "conditions": [
      {"left": "scanner_signal_count", "op": "eq", "right": 0, "label": "no_signal"}
    ]
  },
  "risk": {
    "stop_loss_pct": 0.02,
    "take_profit_pct": null,
    "risk_per_trade_pct": 0.02,
    "trailing_stop_pct": null
  },
  "metadata": {
    "created_at": "2026-02-27",
    "deprecated_date": "2026-03-09",
    "deprecated_reason": "pattern_alert로 교체",
    "tags": ["scanner", "composite", "multi-strategy", "upbit", "deprecated"],
    "successor": "engine/strategy/pattern_alert.py"
  }
}
