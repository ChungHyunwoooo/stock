{
  "name": "Swing Scanner (6종)",
  "version": "1.0",
  "status": "deprecated",
  "description": "스윙 트레이딩용 6종 개별 스캐너 복합체. 개별 파일 난립 문제로 pattern_alert 단일 오케스트레이터로 통합 후 폐기.",
  "markets": ["crypto_futures"],
  "direction": "both",
  "timeframes": ["1h", "4h", "1d"],
  "indicators": [
    {"name": "EMA", "params": {"timeperiod": 21}, "output": "ema_21"},
    {"name": "EMA", "params": {"timeperiod": 55}, "output": "ema_55"},
    {"name": "RSI", "params": {"timeperiod": 14}, "output": "rsi_14"},
    {"name": "ATR", "params": {"timeperiod": 14}, "output": "atr_14"},
    {"name": "MACD", "params": {"fastperiod": 12, "slowperiod": 26, "signalperiod": 9}, "output": {"macd": "macd", "signal": "macd_signal", "hist": "macd_hist"}}
  ],
  "entry": {
    "logic": "or",
    "conditions": [
      {"left": "swing_signal_count", "op": "gte", "right": 2, "label": "composite_swing_signal"}
    ]
  },
  "exit": {
    "logic": "or",
    "conditions": [
      {"left": "swing_signal_count", "op": "eq", "right": 0, "label": "no_swing_signal"}
    ]
  },
  "risk": {
    "stop_loss_pct": 0.02,
    "take_profit_pct": null,
    "risk_per_trade_pct": 0.02,
    "trailing_stop_pct": null
  },
  "metadata": {
    "created_at": "2026-02-27",
    "deprecated_date": "2026-03-09",
    "deprecated_reason": "pattern_alert로 교체",
    "tags": ["scanner", "swing", "composite", "multi-strategy", "deprecated"],
    "successor": "engine/strategy/pattern_alert.py"
  }
}
